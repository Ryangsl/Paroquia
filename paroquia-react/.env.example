# Copie este arquivo para .env e defina as variaveis abaixo
# O arquivo .env NÃO deve ser commitado no repositório

# Senha do painel admin
VITE_ADMIN_KEY=sua_senha_aqui

# Web3Forms — chave de acesso para o formulario de contato
# Crie gratuitamente em https://web3forms.com com o email da paroquia
VITE_WEB3FORMS_KEY=sua_chave_aqui
